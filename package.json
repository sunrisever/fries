{
  "name": "fries",
  "private": true,
  "version": "0.4.0-beta",
  "description": "薯条 | Fries",
  "author": "sunrisever",
  "license": "MIT",
  "homepage": "https://github.com/sunrisever/fries",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunrisever/fries.git"
  },
  "bugs": {
    "url": "https://github.com/sunrisever/fries/issues"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/self-check.test.cjs",
    "check:examples": "node scripts/check-examples.cjs",
    "check:release": "node scripts/check-release.cjs",
    "self-check": "node scripts/run-self-check.cjs",
    "repair:history": "node scripts/repair-history-signatures.cjs",
    "check": "npm run typecheck && npm run test && npm run check:examples && npm run check:release && npm run build",
    "build": "vite build",
    "preview": "vite preview",
    "pack:dir": "npm run build && electron-builder --publish never --win dir",
    "pack:portable": "npm run build && electron-builder --publish never --win portable",
    "pack:installer": "npm run build && electron-builder --publish never --win nsis",
    "pack:linux": "npm run build && electron-builder --publish never --linux AppImage deb",
    "pack:mac": "npm run build && electron-builder --publish never --mac zip dmg",
    "pack:release": "npm run build && electron-builder --publish never --win nsis portable",
    "release:beta": "npm run check && electron-builder --publish never --win nsis portable",
    "dist": "npm run pack:release"
  },
  "build": {
    "appId": "com.sunrisever.fries",
    "productName": "Fries",
    "copyright": "Copyright © 2026 sunrisever",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "src/assets/**/*",
      "public/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sunrisever",
        "repo": "fries",
        "releaseType": "release"
      }
    ],
    "win": {
      "artifactName": "Fries-${version}-${arch}.${ext}",
      "icon": "build/icon.ico",
      "publish": [
        {
          "provider": "github",
          "owner": "sunrisever",
          "repo": "fries",
          "releaseType": "release"
        }
      ]
    },
    "nsis": {
      "artifactName": "Fries-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fries"
    },
    "portable": {
      "artifactName": "Fries-Portable-${version}-${arch}.${ext}"
    },
    "linux": {
      "artifactName": "Fries-${version}-${arch}.${ext}",
      "icon": "build/icon.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "artifactName": "Fries-${version}-${arch}.${ext}",
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "target": [
        "zip",
        "dmg"
      ]
    }
  },
  "dependencies": {
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  }
}
